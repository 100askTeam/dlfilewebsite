[Unit]
Description=dladmin-go download site
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/home1/dlfile
Environment=HOST=127.0.0.1
Environment=PORT=5000
ExecStart=/home1/dlfile/dladmin-go
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
